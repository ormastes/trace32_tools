# T32 MCP — Window tool handlers
# Handles: window_list, window_open, window_capture, window_describe, screenshot

use app.t32_cli.error_codes.{T4030, T4082, t32_err_window_not_found, t32_err_missing_param, t32_err_no_session_mcp}

# --- Window catalog from SDN files (REQ-F5-003: no silent fallback) ---
# Loads from config/t32/catalogs/windows.sdn at startup.
# Returns empty catalog with error on parse failure — never falls back to hardcoded.

fn t32_get_window_catalog() -> [text]:
    val sdn_path = "config/t32/catalogs/windows.sdn"
    val sdn_content = rt_file_read_text(sdn_path) ?? ""
    var catalog: [text] = []
    if sdn_content == "":
        t32_stderr("[window_tools] ERROR: SDN catalog not found or empty: {sdn_path}")
        return catalog
    catalog = t32_parse_window_sdn(sdn_content)
    if t32_text_list_len(catalog) == 0:
        t32_stderr("[window_tools] ERROR: SDN catalog parsed zero entries from: {sdn_path}")
    catalog

# Parse SDN window entries into pipe-delimited catalog strings
fn t32_parse_window_sdn(content: text) -> [text]:
    var catalog: [text] = []
    var key = ""
    var title = ""
    var kind = ""
    var open_cmd = ""
    var capture_cmd = ""
    var capture_mode = ""
    var arch = ""
    var notes = ""
    var in_entry = false
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.len() == 0:
            continue
        if trimmed.starts_with("#"):
            continue
        if trimmed.starts_with("window "):
            # Save previous entry
            if in_entry and key != "":
                catalog.push("{key}|{title}|{kind}|{open_cmd}|{capture_cmd}|{capture_mode}|{arch}|{notes}")
            key = trimmed.substring(7).trim()
            title = ""
            kind = ""
            open_cmd = ""
            capture_cmd = ""
            capture_mode = ""
            arch = ""
            notes = ""
            in_entry = true
            continue
        if in_entry:
            if trimmed.starts_with("title:"):
                title = trimmed.substring(6).trim()
            elif trimmed.starts_with("kind:"):
                kind = trimmed.substring(5).trim()
            elif trimmed.starts_with("open_command:"):
                open_cmd = trimmed.substring(13).trim()
            elif trimmed.starts_with("capture_command:"):
                capture_cmd = trimmed.substring(16).trim()
            elif trimmed.starts_with("capture_mode:"):
                capture_mode = trimmed.substring(13).trim()
            elif trimmed.starts_with("arch:"):
                arch = trimmed.substring(5).trim()
            elif trimmed.starts_with("notes:"):
                notes = trimmed.substring(6).trim()
    # Save last entry
    if in_entry and key != "":
        catalog.push("{key}|{title}|{kind}|{open_cmd}|{capture_cmd}|{capture_mode}|{arch}|{notes}")
    catalog

fn t32_find_colon(s: text) -> i64:
    var i = 0
    while i < s.len():
        if s[i] == ":":
            return i
        i = i + 1
    -1

