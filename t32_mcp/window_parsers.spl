    val lines = wp_split_lines(raw)
    var rows: [[text]] = []
    for line in lines:
        val trimmed = wp_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("module"):
            continue
        val tokens = wp_split_ws(trimmed)
        if tokens.len() >= 4:
            rows.push([tokens[0], tokens[1], tokens[2], tokens[3]])
    wp_rows_to_json(rows, ["module", "time", "calls", "percent"])

fn wp_parse_mmu(raw: text) -> text:
    val lines = wp_split_lines(raw)
    var rows: [[text]] = []
    for line in lines:
        val trimmed = wp_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("virt"):
            continue
        val tokens = wp_split_ws(trimmed)
        if tokens.len() >= 4:
            rows.push([tokens[0], tokens[1], tokens[2], tokens[3]])
    wp_rows_to_json(rows, ["virt_addr", "phys_addr", "size", "perms"])

fn wp_parse_peripheral(raw: text) -> text:
    val lines = wp_split_lines(raw)
    var rows: [[text]] = []
    for line in lines:
        val trimmed = wp_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("name"):
            continue
        val tokens = wp_split_ws(trimmed)
        if tokens.len() >= 4:
            rows.push([tokens[0], tokens[1], tokens[2], tokens[3]])
    wp_rows_to_json(rows, ["name", "address", "value", "bits"])

fn wp_parse_data_list(raw: text) -> text:
    val lines = wp_split_lines(raw)
    var rows: [[text]] = []
    for line in lines:
        val trimmed = wp_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("address"):
            continue
        val tokens = wp_split_ws(trimmed)
        if tokens.len() >= 2:
            var instruction = tokens[1]
            var symbol = ""
            if tokens.len() >= 3:
                symbol = tokens[tokens.len() - 1]
                var ii = 2
                while ii < tokens.len() - 1:
                    instruction = instruction + " " + tokens[ii]
                    ii = ii + 1
            rows.push([tokens[0], instruction, symbol])
    wp_rows_to_json(rows, ["address", "instruction", "symbol"])

fn wp_parse_area(raw: text) -> text:
    val lines = wp_split_lines(raw)
    var arr = t32_SB_L()
    var first = true
    for line in lines:
        if not first:
            arr = arr + ","
        first = false
        arr = arr + t32_js(line)
    arr = arr + t32_SB_R()
    t32_jo1(t32_jp("lines", arr))

# --- Dispatcher: window_key → JSON parser ---

fn t32_parse_window_to_json(window_key: text, raw_text: text) -> text:
    if window_key == "register_view":
        return wp_parse_register(raw_text)
    if window_key == "break_list":
        return wp_parse_break_list(raw_text)
    if window_key == "var_watch":
        return wp_parse_var_watch(raw_text)
    if window_key == "var_local":
        return wp_parse_var_watch(raw_text)
    if window_key == "trace_list":
        return wp_parse_trace_list(raw_text)
    if window_key == "task_list":
        return wp_parse_task_list(raw_text)
    if window_key == "stack_frame":
        return wp_parse_stack_frame(raw_text)
    if window_key == "data_dump":
        return wp_parse_memory_dump(raw_text)
    if window_key == "source_list":
        return wp_parse_source_list(raw_text)
    if window_key == "coverage_list":
        return wp_parse_coverage(raw_text)
    if window_key == "symbol_browse":
        return wp_parse_symbol_browse(raw_text)
    if window_key == "perf_list":
        return wp_parse_perf(raw_text)
    if window_key == "mmu_list":
        return wp_parse_mmu(raw_text)
    if window_key == "per_view":
        return wp_parse_peripheral(raw_text)
    if window_key == "data_list":
        return wp_parse_data_list(raw_text)
    if window_key == "semihost_area":
        return wp_parse_area(raw_text)
    # Unknown window — return raw as single-element JSON
    t32_jo1(t32_jp("raw", t32_js(raw_text)))
