# CMM GUI-to-CLI Conversion Validation Test
#
# Validates that all expected_cli/ files are correct conversions of
# their originals: GUI commands removed, functional content preserved.
#
# Usage:
#   bin/release/simple examples/10_tooling/trace32_tools/cmm_lsp/test_cli_conversion.spl

use cmm_parser.{parse_cmm_source}
use cmm_text_helpers.{is_cmm_file, has_dot, dir_of, check_gui_keywords, check_has_command}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn sys_get_args() -> [text]

# ---------------------------------------------------------------------------
# String utilities
# ---------------------------------------------------------------------------

fn count_lines(content: text) -> i64:
    if content.len() == 0:
        return 0
    var count = 1
    var i = 0
    while i < content.len():
        if content[i:i + 1] == "\n":
            count = count + 1
        i = i + 1
    count

# ---------------------------------------------------------------------------
# File collection helpers
# ---------------------------------------------------------------------------

fn collect_cmm_files_recursive(dir: text) -> [text]:
    var results: [text] = []
    val entries = rt_dir_list(dir)
    var i = 0
    while i < entries.len():
        val entry = entries[i]
        if entry != "." and entry != "..":
            val full_path = dir + "/" + entry
            if is_cmm_file(entry):
                results.push(full_path)
            else if not has_dot(entry):
                val sub = collect_cmm_files_recursive(full_path)
                var si = 0
                while si < sub.len():
                    results.push(sub[si])
                    si = si + 1
        i = i + 1
    results

fn short_name(path: text, base: text) -> text:
    val prefix = base + "/"
    if path.len() > prefix.len():
        if path[0:prefix.len()] == prefix:
            return path[prefix.len():path.len()]
    path

# ---------------------------------------------------------------------------
# Check 4: Labels extraction
# ---------------------------------------------------------------------------

fn extract_labels(content: text) -> [text]:
    var labels: [text] = []
    val lines = content.split("\n")
    var li = 0
    while li < lines.len():
        val trimmed = lines[li].trim_start()
        if trimmed.len() > 1 and trimmed.ends_with(":"):
            # Not a comment
            if not trimmed.starts_with(";"):
                val name = trimmed[0:trimmed.len() - 1]
                if not name.contains(" "):
                    labels.push(name)
        li = li + 1
    labels

# ---------------------------------------------------------------------------
# Check 5: Functional content prefix counting
# ---------------------------------------------------------------------------

fn count_prefix(content: text, prefix: text) -> i64:
    var count = 0
    val lines = content.split("\n")
    var li = 0
    while li < lines.len():
        val trimmed = lines[li].trim_start()
        val lowered = trimmed.to_lower()
        if lowered.starts_with(prefix):
            count = count + 1
        li = li + 1
    count

# ---------------------------------------------------------------------------
# Path derivation
# ---------------------------------------------------------------------------

fn derive_original_path(expected_path: text, fixtures_dir: text) -> text:
    # expected: {fixtures_dir}/expected_cli/riscv/foo.cmm
    # original: {fixtures_dir}/riscv/foo.cmm
    val marker = "/expected_cli/"
    var idx = -1
    var i = 0
    while i <= expected_path.len() - marker.len():
        if expected_path[i:i + marker.len()] == marker:
            idx = i
        i = i + 1
    if idx >= 0:
        return expected_path[0:idx] + "/" + expected_path[idx + marker.len():expected_path.len()]
    expected_path

# ---------------------------------------------------------------------------
# Check 7: Bare GUI window command detection
# ---------------------------------------------------------------------------

fn check_bare_gui_commands(content: text) -> [text]:
    val bare_cmds: [text] = ["data.list", "register.view", "var.frame", "trace.list", "task.list", "data.dump", "var.view", "task.dtask", "per.view"]
    var violations: [text] = []
    val lines = content.split("\n")
    var li = 0
    while li < lines.len():
        val trimmed = lines[li].trim_start()
        if trimmed.len() == 0:
            li = li + 1
            continue
        val lowered = trimmed.to_lower()
        if lowered.starts_with(";"):
            li = li + 1
            continue
        # Skip if it's a WinPrint command
        if lowered.starts_with("winprint."):
            li = li + 1
            continue
        var bi = 0
        while bi < bare_cmds.len():
            val cmd = bare_cmds[bi]
            if lowered.starts_with(cmd):
                if lowered.len() == cmd.len():
                    violations.push(cmd)
                else:
                    val next_ch = lowered[cmd.len():cmd.len() + 1]
                    if next_ch == " " or next_ch == "\t" or next_ch == "\n":
                        violations.push(cmd)
            bi = bi + 1
        li = li + 1
    violations

# ---------------------------------------------------------------------------
# Main runner
# ---------------------------------------------------------------------------

fn run_cli_conversion_tests():
    val all_args = sys_get_args()
    var script_dir = ""
    if all_args.len() > 0:
        script_dir = dir_of(all_args[0])
    var fixtures_dir = script_dir + "/test_fixtures"
    if script_dir == "":
        fixtures_dir = "examples/10_tooling/trace32_tools/test_fixtures"

    val expected_cli_dir = fixtures_dir + "/expected_cli"

    print "=== CMM CLI Conversion Validation ==="
    print "Fixtures: {fixtures_dir}"
    print ""

    val expected_files = collect_cmm_files_recursive(expected_cli_dir)
    if expected_files.len() == 0:
        print "ERROR: No expected CLI files found in {expected_cli_dir}"
        return

    print "Found {expected_files.len()} expected CLI files"
    print ""

    var total_files = 0
    var passed_files = 0
    var failed_files = 0
    var total_checks = 0
    var passed_checks = 0
    var failed_checks = 0

    val functional_prefixes: [text] = ["flash.", "break.set", "data.load", "system.", "register.set", "gosub "]

    var fi = 0
    while fi < expected_files.len():
        val expected_path = expected_files[fi]
        val original_path = derive_original_path(expected_path, fixtures_dir)
        val display_name = short_name(expected_path, expected_cli_dir)

        total_files = total_files + 1
        var file_checks = 0
        var file_pass = 0
        var file_errors: [text] = []

        # Read both files
        val expected_content = rt_file_read_text(expected_path) ?? ""
        val original_content = rt_file_read_text(original_path) ?? ""

        if expected_content == "" or original_content == "":
            print "  SKIP {display_name}  (file read failed)"
            fi = fi + 1
            continue

        # --- Check 1: Parse validation ---
        file_checks = file_checks + 1
        val expected_prog = parse_cmm_source(expected_content)
        val original_prog = parse_cmm_source(original_content)
        if expected_prog.errors.len() == 0 and original_prog.errors.len() == 0:
            file_pass = file_pass + 1
        else:
            var msg = "Parse errors:"
            if original_prog.errors.len() > 0:
                msg = msg + " original=" + original_prog.errors[0]
            if expected_prog.errors.len() > 0:
                msg = msg + " expected=" + expected_prog.errors[0]
            file_errors.push(msg)

        # --- Check 2: GUI keyword absence ---
        file_checks = file_checks + 1
        val gui_violations = check_gui_keywords(expected_content)
        if gui_violations.len() == 0:
            file_pass = file_pass + 1
        else:
            file_errors.push("GUI keyword found: \"{gui_violations[0]}\"")

        # --- Check 3: Line count (informational) ---
        file_checks = file_checks + 1
        val expected_lines = count_lines(expected_content)
        val original_lines = count_lines(original_content)
        file_pass = file_pass + 1
        if expected_lines > original_lines:
            print "       (info) CLI longer than original: {expected_lines} vs {original_lines} lines"

        # --- Check 4: ENDDO + labels preserved ---
        file_checks = file_checks + 1
        val has_enddo = expected_content.contains("ENDDO")
        val orig_labels = extract_labels(original_content)
        val expected_labels = extract_labels(expected_content)
        var labels_ok = has_enddo
        var missing_label = ""
        var oi = 0
        while oi < orig_labels.len():
            val label = orig_labels[oi]
            var found = false
            var ei = 0
            while ei < expected_labels.len():
                if expected_labels[ei] == label:
                    found = true
                ei = ei + 1
            if not found:
                labels_ok = false
                missing_label = label
            oi = oi + 1
        if labels_ok:
            file_pass = file_pass + 1
        else:
            if not has_enddo:
                file_errors.push("Missing ENDDO")
            else:
                file_errors.push("Missing label: {missing_label}")

        # --- Check 5: Functional content preserved ---
        file_checks = file_checks + 1
        var content_ok = true
        var content_err = ""
        var pi = 0
        while pi < functional_prefixes.len():
            val prefix = functional_prefixes[pi]
            val orig_count = count_prefix(original_content, prefix)
            val exp_count = count_prefix(expected_content, prefix)
            # CLI conversion preserves or adds functional commands, never removes
            if exp_count < orig_count:
                content_ok = false
                content_err = "{prefix} count: expected={exp_count} < original={orig_count}"
            pi = pi + 1
        if content_ok:
            file_pass = file_pass + 1
        else:
            file_errors.push(content_err)

        # --- Check 6: SCREEN.OFF present ---
        file_checks = file_checks + 1
        val has_screen_off = check_has_command(expected_content, "screen.off")
        if has_screen_off:
            file_pass = file_pass + 1
        else:
            file_errors.push("Missing SCREEN.OFF")

        # --- Check 7: No bare GUI window commands ---
        file_checks = file_checks + 1
        val bare_gui_violations = check_bare_gui_commands(expected_content)
        if bare_gui_violations.len() == 0:
            file_pass = file_pass + 1
        else:
            file_errors.push("Bare GUI command: \"{bare_gui_violations[0]}\"")

        # --- Check 8: Error handler present ---
        file_checks = file_checks + 1
        val lower_expected = expected_content.to_lower()
        val has_error_handler = (lower_expected.contains("on error") or lower_expected.contains("on.error") or lower_expected.contains("globalon error"))
        if has_error_handler:
            file_pass = file_pass + 1
        else:
            file_errors.push("Missing ON ERROR handler")

        # --- Check 9: Metadata header ---
        file_checks = file_checks + 1
        val has_target = expected_content.contains("@target:")
        val has_purpose = expected_content.contains("@purpose:")
        if has_target and has_purpose:
            file_pass = file_pass + 1
        else:
            var missing = ""
            if not has_target: missing = "@target:"
            if not has_purpose: missing = missing + " @purpose:"
            file_errors.push("Missing metadata: {missing}")

        # --- Check 10: ENDDO with return value ---
        file_checks = file_checks + 1
        val has_enddo_true = expected_content.contains("ENDDO TRUE()")
        val has_enddo_false = expected_content.contains("ENDDO FALSE()")
        if has_enddo_true or has_enddo_false:
            file_pass = file_pass + 1
        else:
            file_errors.push("Missing ENDDO TRUE()/FALSE()")

        # --- Check 11: AREA channel setup ---
        file_checks = file_checks + 1
        val has_area_create = lower_expected.contains("area.create")
        val has_area_select = lower_expected.contains("area.select")
        if has_area_create and has_area_select:
            file_pass = file_pass + 1
        else:
            file_errors.push("Missing AREA.Create/Select")

        # --- Report per file ---
        total_checks = total_checks + file_checks
        passed_checks = passed_checks + file_pass
        failed_checks = failed_checks + (file_checks - file_pass)

        if file_pass == file_checks:
            passed_files = passed_files + 1
            print "  OK   {display_name}  ({file_pass}/{file_checks} checks)"
        else:
            failed_files = failed_files + 1
            print "  FAIL {display_name}  ({file_pass}/{file_checks} checks)"
            var ei = 0
            while ei < file_errors.len():
                print "       -> {file_errors[ei]}"
                ei = ei + 1

        fi = fi + 1

    # Summary
    print ""
    print "=== Summary ==="
    print "Files: {total_files}  Passed: {passed_files}  Failed: {failed_files}"
    print "Checks: {total_checks}  Passed: {passed_checks}  Failed: {failed_checks}"
    print ""
    if failed_files == 0:
        print "ALL CLI CONVERSIONS PASSED"
    else:
        print "{failed_files} CONVERSION(S) FAILED"

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

run_cli_conversion_tests()
