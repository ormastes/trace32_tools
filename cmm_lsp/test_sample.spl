# Quick sample test: parse first N CMM files from /opt/t32/demo
use cmm_parser.{parse_cmm_source}
use cmm_text_helpers.{is_cmm_file, has_dot}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]


fn collect_cmm(root: text) -> [text]:
    var result: [text] = []
    var dirs: [text] = [root]
    var di = 0
    while di < dirs.len():
        val dir = dirs[di]
        di = di + 1
        val entries = rt_dir_list(dir)
        var ei = 0
        while ei < entries.len():
            val e = entries[ei]
            if e != "." and e != "..":
                val full = dir + "/" + e
                if is_cmm_file(e):
                    result.push(full)
                if not is_cmm_file(e) and not has_dot(e):
                    dirs.push(full)
            ei = ei + 1
    result

fn parse_file(path: text) -> text:
    val content = rt_file_read_text(path) ?? ""
    if content.len() > 30:
        val header = content[0:30].to_lower()
        if header.starts_with("trace32 encrypted"):
            return "skip"
    val p = parse_cmm_source(content)
    if p.errors.len() == 0:
        return "ok"
    p.errors[0]

val target = "/opt/t32/demo"
print "Collecting CMM files from {target}..."
val files = collect_cmm(target)
print "Found {files.len()} CMM files, testing first 50"

var ok_count = 0
var fail_count = 0
var skip_count = 0
var err_lines: [text] = []

var i = 0
while i < files.len():
    if i >= 50:
        i = files.len()
    if i < 50:
        val result = parse_file(files[i])
        if result == "ok":
            ok_count = ok_count + 1
        if result == "skip":
            skip_count = skip_count + 1
        if result != "ok" and result != "skip":
            fail_count = fail_count + 1
            if err_lines.len() < 30:
                err_lines.push(files[i] + ": " + result)
        if i > 0 and i % 50 == 0:
            print "  ... {i} files processed"
        i = i + 1

print ""
print "=== Results ==="
print "OK:      {ok_count}"
print "FAIL:    {fail_count}"
print "Skipped: {skip_count}"
val parseable = ok_count + fail_count
if parseable > 0:
    print "Rate:    {ok_count * 100 / parseable}% ({ok_count}/{parseable})"
print ""

if err_lines.len() > 0:
    print "=== First {err_lines.len()} errors ==="
    var ei = 0
    while ei < err_lines.len():
        print err_lines[ei]
        ei = ei + 1
