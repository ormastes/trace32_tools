use cmm_lexer.{lex_cmm_source}
use cmm_tokens.{CmmTokenKind, CmmToken}
use cmm_parser.{parse_cmm_source}

fn show_tokens(source: text):
    val tokens = lex_cmm_source(source)
    var i = 0
    while i < tokens.len():
        val t = tokens[i]
        print "  [{i}] {t.text}"
        i = i + 1

fn test_parse(name: text, source: text):
    val p = parse_cmm_source(source)
    if p.errors.len() > 0:
        print "FAIL {name}: {p.errors[0]}"
    if p.errors.len() == 0:
        print "OK   {name}"

print "=== Tokens: 0x&ADDR&0x03 ==="
show_tokens("(0x22<<(0x&ADDR&0x03))&0x0f\n")

print ""
test_parse("bootseq", "&BYTE_EN=(0x22<<(0x&ADDR&0x03))&0x0f\n")
test_parse("ssr2_and", "if (&ssr2&&ssr2_fba_wp_hdr)==(&ssr2_fba_wp_hdr)\n  PRINT \"yes\"\n")
test_parse("addr_or", "if (&addr<0x600):o:(&addr>9ff)\n  stop \"ERROR\"\n")
test_parse("c_cast", "&pc=v.value(((struct thread_entry)*&thread).reg.gpr[15])\n")
