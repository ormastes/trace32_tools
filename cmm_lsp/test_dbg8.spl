use cmm_parser.{parse_cmm_source}

fn test_parse(name: text, source: text):
    val p = parse_cmm_source(source)
    if p.errors.len() > 0:
        print "FAIL {name}: {p.errors[0]}"
    if p.errors.len() == 0:
        print "OK   {name}"

# Exact patterns from failing files
test_parse("eeprom_az60", "if (&addr<0x600):o:(&addr>9ff)\n  stop \"ERROR\"\n")
test_parse("bootseq_exact", "&BYTE_EN=(0x22<<(0x&ADDR&0x03))&0x0f\n")
test_parse("c_cast", "&pc=v.value(((struct thread_entry)*&thread).reg.gpr[15])\n")
test_parse("ssr2", "if (&ssr2&&ssr2_fba_wp_hdr)==(&ssr2_fba_wp_hdr)\n  PRINT \"yes\"\n")
test_parse("sdram_init", "&SACS2=(d.l(d:(iobase()+010110))&0ffff8000)\n")
