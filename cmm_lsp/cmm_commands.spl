    # --- Trace extended commands ---
    cmds.push(CmmCommandInfo(full_name: "Trace.METHOD", short_name: "Trace.METHOD", group: "Trace", description: "Set trace method", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Trace.SIZE", short_name: "Trace.SIZE", group: "Trace", description: "Set trace buffer size", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Trace.CLOCK", short_name: "Trace.CLOCK", group: "Trace", description: "Set trace clock", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Trace.Init", short_name: "Trace.Init", group: "Trace", description: "Initialize trace", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Trace.STATistic.Func", short_name: "Trace.STATistic.Func", group: "Trace", description: "Show function statistics", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Trace.Chart.Func", short_name: "Trace.Chart.Func", group: "Trace", description: "Show function chart", min_version: "all"))
