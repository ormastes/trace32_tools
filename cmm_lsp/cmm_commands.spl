    cmds.push(CmmCommandInfo(full_name: "RETURNVALUES", short_name: "RETURNVALUES", group: "Declaration", description: "Declare subroutine return values", min_version: "2013"))

    # --- Print-like commands ---
    cmds.push(CmmCommandInfo(full_name: "PRINTF", short_name: "PRINTF", group: "IO", description: "Formatted print output", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "ECHO", short_name: "ECHO", group: "IO", description: "Echo text to output", min_version: "all"))
