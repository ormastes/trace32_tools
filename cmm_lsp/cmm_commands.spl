    # --- Analyzer commands ---
    cmds.push(CmmCommandInfo(full_name: "Analyzer.RESet", short_name: "Analyzer.RESet", group: "Analyzer", description: "Reset analyzer", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Analyzer.AutoFocus", short_name: "Analyzer.AutoFocus", group: "Analyzer", description: "Auto focus analyzer", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Analyzer.TriggerSet", short_name: "Analyzer.TriggerSet", group: "Analyzer", description: "Set analyzer trigger", min_version: "all"))

