    cmds.push(CmmCommandInfo(full_name: "GOTO", short_name: "GOTO", group: "Control", description: "Jump to label", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "GOSUB", short_name: "GOSUB", group: "Control", description: "Call subroutine", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "RETURN", short_name: "RETURN", group: "Control", description: "Return from subroutine", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "JUMPTO", short_name: "JUMPTO", group: "Control", description: "Cross-module jump", min_version: "all"))
