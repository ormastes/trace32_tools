# CMM (PRACTICE Script) Command Database
# Command group database for validation and completion in the CMM Language Server.
#
# T32 commands are dot-separated hierarchical tokens with case-insensitive
# matching.  UPPER case letters in a name indicate the minimum abbreviation
# (short form).  Example: SYStem.CPU -> short form SYS.CPU.
#
# Reference: doc/research/cmm_grammar_research_2026-03-10.md (Section 5)

export CmmCommandInfo, CmmCommandDB
export build_command_db, lookup_command, get_completions, get_group_commands

# ---------------------------------------------------------------------------
# Types
# ---------------------------------------------------------------------------

struct CmmCommandInfo:
    full_name: text          # e.g. "Data.dump"
    short_name: text         # e.g. "D.D"
    group: text              # e.g. "Data"
    description: text        # brief description
    min_version: text        # "2012", "2013", "all"

struct CmmCommandDB:
    commands: [CmmCommandInfo]

# ---------------------------------------------------------------------------
# Database builder
# ---------------------------------------------------------------------------

# Build the built-in command database covering the major T32 command groups.
fn build_command_db() -> CmmCommandDB:
    var cmds: [CmmCommandInfo] = []

    # --- Data commands ---
    cmds.push(CmmCommandInfo(full_name: "Data.dump", short_name: "D.D", group: "Data", description: "Display hex dump of memory", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.List", short_name: "D.L", group: "Data", description: "Display disassembly listing", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.LOAD", short_name: "D.LOAD", group: "Data", description: "Load program file", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.LOAD.auto", short_name: "D.LOAD.auto", group: "Data", description: "Auto-detect format and load", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.SAVE.Binary", short_name: "D.SAVE.B", group: "Data", description: "Save memory as binary file", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.Set", short_name: "D.S", group: "Data", description: "Set memory values", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.Test", short_name: "D.Test", group: "Data", description: "Test memory range", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.Print", short_name: "D.Print", group: "Data", description: "Print memory to file", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.DRAWFFT", short_name: "D.DRAWFFT", group: "Data", description: "Display memory as FFT graph", min_version: "all"))

    # --- SYStem commands ---
    cmds.push(CmmCommandInfo(full_name: "SYStem.CPU", short_name: "SYS.CPU", group: "SYStem", description: "Set CPU type", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.Mode", short_name: "SYS.Mode", group: "SYStem", description: "Set system mode", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.Up", short_name: "SYS.Up", group: "SYStem", description: "Start debug session", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.Down", short_name: "SYS.Down", group: "SYStem", description: "Stop debug session", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.RESet", short_name: "SYS.RESet", group: "SYStem", description: "Reset system", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.state", short_name: "SYS", group: "SYStem", description: "Show system state window", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.Option", short_name: "SYS.Option", group: "SYStem", description: "Set system option", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.MemAccess", short_name: "SYS.MA", group: "SYStem", description: "Set memory access mode", min_version: "all"))

    # --- FLASH commands ---
    cmds.push(CmmCommandInfo(full_name: "FLASH.RESet", short_name: "FLASH.RESet", group: "FLASH", description: "Reset flash configuration", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.Create", short_name: "FLASH.Create", group: "FLASH", description: "Declare flash area", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.AUTO", short_name: "FLASH.AUTO", group: "FLASH", description: "Auto program flash", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.Erase", short_name: "FLASH.Erase", group: "FLASH", description: "Erase flash area", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.Program", short_name: "FLASH.Program", group: "FLASH", description: "Program flash", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.ReProgram", short_name: "FLASH.ReProgram", group: "FLASH", description: "Reprogram flash", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.CLocK", short_name: "FLASH.CLocK", group: "FLASH", description: "Set flash clock", min_version: "all"))

    # --- Break commands ---
    cmds.push(CmmCommandInfo(full_name: "Break.Set", short_name: "B.S", group: "Break", description: "Set breakpoint", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Break.Delete", short_name: "B.D", group: "Break", description: "Delete breakpoint", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Break.List", short_name: "B.L", group: "Break", description: "List breakpoints", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Break.RESet", short_name: "B.RESet", group: "Break", description: "Reset all breakpoints", min_version: "all"))

