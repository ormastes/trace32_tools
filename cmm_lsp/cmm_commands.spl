    cmds.push(CmmCommandInfo(full_name: "AREA.Select", short_name: "AREA.Select", group: "AREA", description: "Select AREA for I/O", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "AREA.view", short_name: "AREA.view", group: "AREA", description: "Open AREA window", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "AREA.RESet", short_name: "AREA.RESet", group: "AREA", description: "Reset AREA system", min_version: "all"))

    # --- SETUP commands ---
