    cmds.push(CmmCommandInfo(full_name: "STATUSBAR", short_name: "STATUSBAR", group: "Misc", description: "Show/hide status bar", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FRAMEPOS", short_name: "FRAMEPOS", group: "Misc", description: "Set frame position", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "TYPE", short_name: "TYPE", group: "Misc", description: "Display file content", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "ChDir.DO", short_name: "CD.DO", group: "Misc", description: "Change dir and run script", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "STOre", short_name: "STOre", group: "Misc", description: "Store settings", min_version: "all"))
