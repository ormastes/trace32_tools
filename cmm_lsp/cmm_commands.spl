    cmds.push(CmmCommandInfo(full_name: "Var.AddWatch", short_name: "V.AddWatch", group: "Var", description: "Add watch expression", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Var.WRITE", short_name: "V.WRITE", group: "Var", description: "Write variable to file", min_version: "all"))

    # --- Trace commands ---
    cmds.push(CmmCommandInfo(full_name: "Trace.LOAD", short_name: "T.LOAD", group: "Trace", description: "Load trace data", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Trace.List", short_name: "T.L", group: "Trace", description: "List trace records", min_version: "all"))

    # --- Window commands ---
    cmds.push(CmmCommandInfo(full_name: "WINPOS", short_name: "WINPOS", group: "Window", description: "Set window position", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "WinPAGE.RESET", short_name: "WinPAGE.RESET", group: "Window", description: "Reset window pages", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "WinCLEAR", short_name: "WinCLEAR", group: "Window", description: "Clear window", min_version: "all"))
