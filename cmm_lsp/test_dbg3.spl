use cmm_parser.{parse_cmm_source}

fn test_parse(name: text, source: text):
    val p = parse_cmm_source(source)
    if p.errors.len() > 0:
        print "FAIL {name}: {p.errors[0]}"
        print "  stmt_count={p.statements.len()} error_count={p.errors.len()}"
    if p.errors.len() == 0:
        print "OK   {name} (stmts={p.statements.len()})"

# Minimal ELSE without IF test
test_parse("minimal_else", "if 1\n(\n  PRINT \"yes\"\n)\nelse\n(\n  PRINT \"no\"\n)\n")

# With && condition
test_parse("and_else", "if 1&&2\n(\n  PRINT \"yes\"\n)\nelse\n(\n  PRINT \"no\"\n)\n")

# With string comparison
test_parse("str_cmp_else", "if \"a\"!=\"\"&&1\n(\n  PRINT \"yes\"\n)\nelse\n(\n  PRINT \"no\"\n)\n")

# Full pattern
test_parse("full_str_and", "if \"&sval\"!=\"\"&&dialog.boolean(HEX)\n(\n  PRINT \"yes\"\n)\nelse if \"&sval\"!=\"\"\n(\n  PRINT \"no\"\n)\n")

# Test & split produces valid parse
test_parse("amp_split", "if \"a\"!=\"\"&1\n(\n  PRINT \"yes\"\n)\nelse\n(\n  PRINT \"no\"\n)\n")
