# Test fixed parser - all patterns
use cmm_parser.{parse_cmm_source}

fn test_parse(name: text, source: text):
    val p = parse_cmm_source(source)
    if p.errors.len() > 0:
        print "FAIL {name}: {p.errors[0]}"
    if p.errors.len() == 0:
        print "OK   {name}"

# Previously failing patterns
test_parse("macro_complex", "  &x=(FOO(\"a\",0)!=-1)\n")
test_parse("if_bang_macro", "  IF !&flag\n    Step\n")
test_parse("goto_empty", "  GOTO\n")
test_parse("gosub_macro", "  GOSUB &func\n")
test_parse("neg_assign", "  &x=-1\n")
test_parse("ne_neg", "  &x=(1!=-1)\n")

# Previously passing (ensure no regression)
test_parse("macro_int", "  &x=5\n")
test_parse("if_dotcmd", "  IF VERSION.BUILD.BASE()>=45520.\n    Step\n")
test_parse("if_else", "  IF &flag\n    PRINT \"yes\"\n  ELSE\n    PRINT \"no\"\n")
test_parse("generic", "  SYStem.CPU ARM\n")
test_parse("block", "  (\n    Step\n    WAIT 10ms\n  )\n")
test_parse("label_cmd", "start:\n  SYStem.CPU ARM\n")
test_parse("local", "  LOCAL &a &b\n")
test_parse("on_error", "  ON ERROR GOTO handler\n")
test_parse("print", "  PRINT \"hello\"\n")

# Real-world complex
test_parse("scan", "  &x=(STRing.SCAN(STRing.UPpeR(\"&p\"),\"PREP\",0)!=-1)\n")
test_parse("if_not_skip", "  IF !&param_skipconfig\n  (\n    SYStem.RESet\n  )\n")
test_parse("if_version", "  IF VERSION.BUILD.BASE()>=45520.\n    &dp=\"/DualPort\"\n")
