# Sample test: parse CMM files from specific directories
use cmm_parser.{parse_cmm_source}
use cmm_text_helpers.{is_cmm_file, has_dot}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]

fn collect_cmm(root: text) -> [text]:
    var result: [text] = []
    var dirs: [text] = [root]
    var di = 0
    while di < dirs.len():
        val dir = dirs[di]
        di = di + 1
        val entries = rt_dir_list(dir)
        var ei = 0
        while ei < entries.len():
            val e = entries[ei]
            if e != "." and e != "..":
                val full = dir + "/" + e
                if is_cmm_file(e):
                    result = result + [full]
                if not is_cmm_file(e) and not has_dot(e):
                    dirs = dirs + [full]
            ei = ei + 1
    result

fn parse_file(path: text) -> text:
    val content = rt_file_read_text(path) ?? ""
    if content.len() > 30:
        val header = content[0:30].to_lower()
        if header.starts_with("trace32 encrypted"):
            return "skip"
    val p = parse_cmm_source(content)
    if p.errors.len() == 0:
        return "ok"
    p.errors[0]

fn test_dir(dirname: text, limit: i64):
    val target = "/opt/t32/demo/" + dirname
    if not rt_file_exists(target):
        print "{dirname}: directory not found"
        return
    val files = collect_cmm(target)
    var ok_count = 0
    var fail_count = 0
    var skip_count = 0
    var errs: [text] = []
    var i = 0
    while i < files.len():
        if i >= limit:
            i = files.len()
        if i < limit:
            val result = parse_file(files[i])
            if result == "ok":
                ok_count = ok_count + 1
            if result == "skip":
                skip_count = skip_count + 1
            if result != "ok" and result != "skip":
                fail_count = fail_count + 1
                if errs.len() < 5:
                    errs = errs + [files[i] + ": " + result]
            i = i + 1
    val parseable = ok_count + fail_count
    var pct = 0
    if parseable > 0:
        pct = ok_count * 100 / parseable
    print "{dirname}: {ok_count}/{parseable} OK ({pct}%), {skip_count} skipped"
    var ei = 0
    while ei < errs.len():
        print "  {errs[ei]}"
        ei = ei + 1

# Test different directories
test_dir("arm/flash", 30)
test_dir("arm/hardware", 30)
test_dir("tricore", 30)
test_dir("powerpc", 30)
test_dir("mips", 30)
