# Sample test: parse CMM files from specific directories
use cmm_parser.{parse_cmm_source}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]

fn to_lower_char(ch: text) -> text:
    if ch == "A": return "a"
    if ch == "B": return "b"
    if ch == "C": return "c"
    if ch == "D": return "d"
    if ch == "E": return "e"
    if ch == "F": return "f"
    if ch == "G": return "g"
    if ch == "H": return "h"
    if ch == "I": return "i"
    if ch == "J": return "j"
    if ch == "K": return "k"
    if ch == "L": return "l"
    if ch == "M": return "m"
    if ch == "N": return "n"
    if ch == "O": return "o"
    if ch == "P": return "p"
    if ch == "Q": return "q"
    if ch == "R": return "r"
    if ch == "S": return "s"
    if ch == "T": return "t"
    if ch == "U": return "u"
    if ch == "V": return "v"
    if ch == "W": return "w"
    if ch == "X": return "x"
    if ch == "Y": return "y"
    if ch == "Z": return "z"
    ch

fn to_lower(s: text) -> text:
    var r = ""
    var i = 0
    while i < s.len():
        r = r + to_lower_char(s[i:i + 1])
        i = i + 1
    r

fn is_cmm(name: text) -> bool:
    if name.len() < 5:
        return false
    to_lower(name[name.len() - 4:name.len()]) == ".cmm"

fn starts_with(s: text, prefix: text) -> bool:
    if prefix.len() > s.len():
        return false
    s[0:prefix.len()] == prefix

fn has_dot(name: text) -> bool:
    var i = 1
    while i < name.len():
        if name[i:i + 1] == ".":
            return true
        i = i + 1
    false

fn collect_cmm(root: text) -> [text]:
    var result: [text] = []
    var dirs: [text] = [root]
    var di = 0
    while di < dirs.len():
        val dir = dirs[di]
        di = di + 1
        val entries = rt_dir_list(dir)
        var ei = 0
        while ei < entries.len():
            val e = entries[ei]
            if e != "." and e != "..":
                val full = dir + "/" + e
                if is_cmm(e):
                    result = result + [full]
                if not is_cmm(e) and not has_dot(e):
                    dirs = dirs + [full]
            ei = ei + 1
    result

fn parse_file(path: text) -> text:
    val content = rt_file_read_text(path) ?? ""
    if content.len() > 30:
        val header = to_lower(content[0:30])
        if starts_with(header, "trace32 encrypted"):
            return "skip"
    val p = parse_cmm_source(content)
    if p.errors.len() == 0:
        return "ok"
    p.errors[0]

fn test_dir(dirname: text, limit: i64):
    val target = "/opt/t32/demo/" + dirname
    if not rt_file_exists(target):
        print "{dirname}: directory not found"
        return
    val files = collect_cmm(target)
    var ok_count = 0
    var fail_count = 0
    var skip_count = 0
    var errs: [text] = []
    var i = 0
    while i < files.len():
        if i >= limit:
            i = files.len()
        if i < limit:
            val result = parse_file(files[i])
            if result == "ok":
                ok_count = ok_count + 1
            if result == "skip":
                skip_count = skip_count + 1
            if result != "ok" and result != "skip":
                fail_count = fail_count + 1
                if errs.len() < 5:
                    errs = errs + [files[i] + ": " + result]
            i = i + 1
    val parseable = ok_count + fail_count
    var pct = 0
    if parseable > 0:
        pct = ok_count * 100 / parseable
    print "{dirname}: {ok_count}/{parseable} OK ({pct}%), {skip_count} skipped"
    var ei = 0
    while ei < errs.len():
        print "  {errs[ei]}"
        ei = ei + 1

# Test different directories
test_dir("arm/flash", 30)
test_dir("arm/hardware", 30)
test_dir("tricore", 30)
test_dir("powerpc", 30)
test_dir("mips", 30)
