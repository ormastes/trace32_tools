use cmm_lexer.{lex_cmm_source}
use cmm_tokens.{CmmTokenKind, CmmToken}
use cmm_parser.{parse_cmm_source}

fn show_tokens(source: text):
    val tokens = lex_cmm_source(source)
    var i = 0
    while i < tokens.len():
        val t = tokens[i]
        print "  [{i}] {t.text}"
        i = i + 1

fn test_parse(name: text, source: text):
    val p = parse_cmm_source(source)
    if p.errors.len() > 0:
        print "FAIL {name}: {p.errors[0]}"
    if p.errors.len() == 0:
        print "OK   {name}"

print "=== Tokens: :o: ==="
show_tokens("if (&addr<0x600):o:(&addr>0x9ff)\n")

test_parse("addr_or", "if (&addr<0x600):o:(&addr>0x9ff)\n  stop \"ERROR\"\n")
test_parse("0x_macro", "&BYTE_EN=(0x22<<(0x&ADDR&0x03))&0x0f\n")
