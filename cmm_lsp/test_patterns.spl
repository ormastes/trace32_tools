use cmm_parser.{parse_cmm_source}

fn test_parse(name: text, source: text):
    val p = parse_cmm_source(source)
    if p.errors.len() > 0:
        print "FAIL {name}: {p.errors[0]}"
    if p.errors.len() == 0:
        print "OK   {name}"

# Test 1: && after string closing quote
test_parse("str_and_dialog", "if \"&sval\"!=\"\"&&dialog.boolean(HEX)\n(\n  PRINT \"yes\"\n)\nelse if \"&sval\"!=\"\"\n(\n  PRINT \"no\"\n)\n")

# Test 2: IF with unbalanced parens 
test_parse("if_unbal_paren", "IF (CPUIS(\"MB9BF116?\")\n(\n  &FlashSize=0x80000\n)\n")

# Test 3: !(fn()&&fn())
test_parse("bang_and_fns", "if !(bdm()&&powerdebug())\n  goto unsupported\n")

# Test 4: local %format
test_parse("local_pct", "local %srcpath\n")

# Test 5: Unterminated string (original has no close quote on the line)
test_parse("untermed_str", "&demofile=\"I:\"+\"\\EVB\\menBambooII.men\nif os.file(&demofile)\n  menu.rp &demofile\n")

# Test 6: Label with colon only (: at line start)
test_parse("colon_label", ":\n; HINTS:\n;\n")

# Test 7: wait.1s — fractional time literal
test_parse("wait_dot1s", "wait.1s\n")

# Test 8: DO ./relative/path.cmm
test_parse("do_rel_path", "DO ./sysup_mc.cmm &cpu &numCores\n")

# Test 9: DO ../relative/path.cmm (already supported)
test_parse("do_dotdot_path", "DO ../load.cmm &ELFfile &core\n")

# Test 10: v.value with C type cast
test_parse("c_typecast", "&pc=v.value(((struct thread_entry)*&thread).reg.gpr[15])\n")

# Test 11: v.value with C pointer cast + arrow dereference
test_parse("c_ptr_cast", "&init=v.value(((struct module*)&magic)->init)\n")

# Test 12: Unclosed function call at EOL (malformed CMM)
test_parse("unclosed_fn_call", "IF CPUIS(\"MSP430F2?9*\")\n(\n  &x=1\n)\nELSE IF CPUIS(\"MSP430AFE22*\"\n(\n  &flashstart=0xF000\n)\n")

# Test 13: ??? placeholder text at statement level
test_parse("qmark_garbage", "if 0==1\n(\n???!!! hier fehlt noch einiges !!!!\n  &p1=string.mid(\"&val\",0.,1.)\n)\n")
