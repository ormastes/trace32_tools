# Parse PER.view (peripheral) output
# Format: GPIOA_MODER  0x48000000  0x28000000  [31:0]
fn parse_peripheral_output(raw: text) -> [Dict<text, text>]:
    val lines = split_lines(raw)
    var rows: [Dict<text, text>] = []

    for line in lines:
        val trimmed = trim(line)
        if trimmed == "":
            continue
        if trimmed.starts_with("#"):
            continue
        if trimmed.starts_with("-"):
            continue
        if trimmed.starts_with("name"):
            continue

        val tokens = split_whitespace(trimmed)
        if tokens.len() >= 4:
            var row: Dict<text, text> = {}
            row["name"] = tokens[0]
            row["address"] = tokens[1]
            row["value"] = tokens[2]
            row["bits"] = tokens[3]
            rows.push(row)

    rows

# Parse Data.List (disassembly) output
# Format: 0x08001234  BL main+0x10  main
fn parse_data_list_output(raw: text) -> [Dict<text, text>]:
    val lines = split_lines(raw)
    var rows: [Dict<text, text>] = []

    for line in lines:
        val trimmed = trim(line)
        if trimmed == "":
            continue
        if trimmed.starts_with("#"):
            continue
        if trimmed.starts_with("-"):
            continue
        if trimmed.starts_with("address"):
            continue

        val tokens = split_whitespace(trimmed)
        if tokens.len() >= 2:
            var row: Dict<text, text> = {}
            row["address"] = tokens[0]
            # instruction is tokens 1..n-1, last token is symbol (if >= 3 tokens)
            var instruction = tokens[1]
            var symbol = ""
            if tokens.len() >= 3:
                symbol = tokens[tokens.len() - 1]
                var ii = 2
                while ii < tokens.len() - 1:
                    instruction = instruction + " " + tokens[ii]
                    ii = ii + 1
            row["instruction"] = instruction
            row["symbol"] = symbol
            rows.push(row)

    rows

# Parse AREA (semihosting output)
# Format: just lines of text
fn parse_area_output(raw: text) -> [text]:
    split_lines(raw)

# Parse Var.Local output — reuses parse_var_watch_output
fn parse_var_local_output(raw: text) -> [Dict<text, text>]:
    parse_var_watch_output(raw)

# Format a list of dicts as an aligned text table
fn format_table(headers: [text], rows: [Dict<text, text>]) -> text:
    if headers.len() == 0:
        return "(empty table)"

    # Calculate column widths
    var widths: [i64] = []
    for h in headers:
        widths.push(h.len())

    for row in rows:
        var col = 0
        while col < headers.len():
            val key = headers[col]
            val val_text = row.get(key) ?? ""
            if val_text.len() > widths[col]:
                widths[col] = val_text.len()
            col = col + 1

    # Build header line
    var header_line = ""
    var separator = ""
    var col = 0
    while col < headers.len():
        if col > 0:
            header_line = header_line + "  "
            separator = separator + "  "
        header_line = header_line + headers[col]
        var pad_needed = widths[col] - headers[col].len()
        while pad_needed > 0:
            header_line = header_line + " "
            pad_needed = pad_needed - 1
        var dash_count = widths[col]
        while dash_count > 0:
            separator = separator + "-"
            dash_count = dash_count - 1
        col = col + 1

    var out = header_line + "\n"
    out = out + separator + "\n"

    # Build data rows
    for row in rows:
        var line = ""
        var rc = 0
        while rc < headers.len():
            if rc > 0:
                line = line + "  "
            val key = headers[rc]
            val val_text = row.get(key) ?? ""
            line = line + val_text
            var pad_needed = widths[rc] - val_text.len()
            while pad_needed > 0:
                line = line + " "
                pad_needed = pad_needed - 1
            rc = rc + 1
        out = out + line + "\n"

    out
