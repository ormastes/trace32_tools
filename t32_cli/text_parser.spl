# Parse MMU.List output
# Format: 0x00000000  0x80000000  0x00100000  RWX
fn parse_mmu_output(raw: text) -> [Dict<text, text>]:
    val lines = split_lines(raw)
    var rows: [Dict<text, text>] = []

    for line in lines:
        val trimmed = trim(line)
        if trimmed == "":
            continue
        if trimmed.starts_with("#"):
            continue
        if trimmed.starts_with("-"):
            continue
        if trimmed.starts_with("virt"):
            continue

        val tokens = split_whitespace(trimmed)
